# Simulate a Connector Gateway OnNewEmail trigger callback against the local
# `func start` host. Use the VS Code REST Client extension (humao.rest-client)
# and click "Send Request" above any request below.
#
# Python sample: function_app.py (Azure Functions v2 programming model)
#
# Environment variables (override with a .env file in this folder if you like):
#   FUNCTION_APP_URL  - http://localhost:7071 for `func start`
#                       https://<app>.azurewebsites.net for deployed app
#   HTTP_POST_CODE    - leave empty for local `func start`
#                       For a deployed app, fetch the connector_extension key:
#                         az functionapp keys list -g <rg> -n <app> \
#                           --query systemKeys.connector_extension -o tsv

@functionAppUrl = {{$dotenv FUNCTION_APP_URL}}
@httpPostCode   = {{$dotenv HTTP_POST_CODE}}

### --- Simulate Connector Gateway OnNewEmail trigger callback -----------------
### Office365OnNewEmailTriggerPayload (the typed SDK model in function_app.py)
### wraps a batch: { "body": { "value": [ <message>, ... ] } }
POST {{functionAppUrl}}/runtime/webhooks/connector?functionName=OnNewEmail&code={{httpPostCode}}
content-type: application/json

{
  "body": {
    "value": [
      {
        "id": "AAMkADlmOTA3NWNm",
        "receivedDateTime": "2026-05-18T10:30:00+00:00",
        "hasAttachments": false,
        "subject": "Hello from test.http",
        "bodyPreview": "Testing the OnNewEmail trigger locally.",
        "importance": "normal",
        "isRead": false,
        "isHtml": true,
        "body": "<html><body>Testing the OnNewEmail trigger locally.</body></html>",
        "from": "someone@contoso.com",
        "toRecipients": "you@contoso.com",
        "ccRecipients": null,
        "bccRecipients": null,
        "replyTo": null,
        "attachments": []
      }
    ]
  }
}

### --- Second request: high-importance email --------------------------------
POST {{functionAppUrl}}/runtime/webhooks/connector?functionName=OnNewEmail&code={{httpPostCode}}
content-type: application/json

{
  "body": {
    "value": [
      {
        "id": "AAMkADlmOTA3NWNn",
        "receivedDateTime": "2026-05-18T11:00:00+00:00",
        "hasAttachments": true,
        "subject": "[URGENT] please review connector demo",
        "bodyPreview": "Need your sign-off before tomorrow.",
        "importance": "high",
        "isRead": false,
        "isHtml": true,
        "body": "<html><body>Need your sign-off before tomorrow.</body></html>",
        "from": "boss@contoso.com",
        "toRecipients": "you@contoso.com",
        "ccRecipients": null,
        "bccRecipients": null,
        "replyTo": null,
        "attachments": []
      }
    ]
  }
}
